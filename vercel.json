{
  "buildCommand": "pnpm install && pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "env": {
    "VITE_API_URL": "https://web-production-fc7223.up.railway.app"
  },
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "destination": "https://web-production-fc7223.up.railway.app/api$1"
    },
    {
      "src": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

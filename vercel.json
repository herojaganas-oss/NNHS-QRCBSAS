{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "envPrefix": "VITE_",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://web-production-fc7223.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

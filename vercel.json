{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "web-production-fc7223.up.railway.app"
  },
  "routes": [
    {
      "src": "^/api(/.*)?$",
      "destination": "https://your-railway-url.railway.app/api$1"
    },
    {
      "src": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
